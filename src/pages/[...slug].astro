---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import MainContent from '../components/MainContent.astro'
import ModuleRenderer from '../components/ModuleRenderer.astro'

// M2 renders only the legal pages. The homepage (/) is excluded from
// static paths; it is migrated in M3.
export async function getStaticPaths() {
  const legalSlugs = new Set(['imprint', 'data-policy'])
  const normalize = (slug: string): string =>
    slug.replace(/^\/+/, '').replace(/\/+$/, '')
  const pages = await getCollection('pages')
  return pages
    .filter(page => legalSlugs.has(normalize(page.data.slug)))
    .map(page => ({
      params: { slug: normalize(page.data.slug) },
      props: { page },
    }))
}

const { page } = Astro.props
const title = page.data.slug === '/data-policy' ? 'Datenschutzhinweis' : 'Impressum'
const modules = page.data.module as unknown as {
  __typename: string
  [key: string]: unknown
}[]
---

<Layout title={title}>
  <MainContent gridRow="2">
    {modules.map(mod => <ModuleRenderer module={mod} />)}
  </MainContent>
</Layout>
